@model EyewaysMergeSafeServer.ViewModels.SettingsViewModel
@{ ViewData["Title"] = "Settings"; ViewBag.Highways = null; }

<div class="mss-page-header">
    <div><h2 class="mss-page-title">Settings</h2><p class="mss-page-sub">Manage highway configurations and API keys</p></div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#hwModal" onclick="openNew()">
        <i class="bi bi-plus me-1"></i>Add Highway
    </button>
</div>

<div class="mss-card mb-4">
    <div class="mss-card-header"><i class="bi bi-key me-1"></i> External API Keys</div>
    <div class="mss-card-body">
        <p class="text-muted small mb-2">TomTom API key for real-time traffic flow in 3D visualization.</p>
        <form method="post" asp-action="SaveTomTomKey" class="d-flex gap-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="flex-fill">
                <label class="form-label small">TomTom API Key</label>
                <div class="input-group">
                    <input type="password" name="apiKey" id="tomtomKey" class="form-control form-control-sm font-monospace"
                           value="@Model.TomTomApiKey" placeholder="Paste your key…" />
                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleTomKey()">
                        <i class="bi bi-eye" id="tomkeyIcon"></i>
                    </button>
                </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">
                @if (TempData["KeySaved"] != null) { <span><i class="bi bi-check-circle me-1"></i>Saved!</span> }
                else { <span><i class="bi bi-save me-1"></i>Save Key</span> }
            </button>
        </form>
    </div>
</div>

<div class="mss-card">
    <div class="mss-card-header"><i class="bi bi-sign-intersection me-1"></i> Highways</div>
    <div class="table-responsive">
        <table class="table table-dark table-hover table-sm mb-0">
            <thead><tr><th>Name</th><th>Highway ID</th><th>State</th><th>Description</th><th>Active</th><th></th></tr></thead>
            <tbody>
            @foreach (var h in Model.Highways)
            {
                <tr>
                    <td class="fw-semibold">@h.Name</td>
                    <td class="font-monospace small">@h.HighwayId</td>
                    <td>@h.State</td>
                    <td class="text-muted small">@h.Description</td>
                    <td>@Html.Raw(h.IsActive ? "<span class='text-success'>●</span>" : "<span class='text-muted'>○</span>")</td>
                    <td class="text-end">
                        <button class="btn btn-outline-secondary btn-sm me-1"
                            onclick="openEdit(@h.Id,'@h.Name','@h.HighwayId','@(h.State ?? "")','@(h.Description ?? "")',@h.IsActive.ToString().ToLower())"
                            data-bs-toggle="modal" data-bs-target="#hwModal">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form method="post" asp-action="Delete" asp-route-id="@h.Id" style="display:inline"
                              onsubmit="return confirm('Delete highway @h.Name?')">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Highways.Any())
            { <tr><td colspan="6" class="text-muted text-center py-4">No highways configured.</td></tr> }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="hwModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content mss-modal">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title" id="hwModalTitle">Add Highway</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="hwForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="hw_id" value="0" />
            <div class="row g-2">
                <div class="col-12"><label class="form-label small">Highway Name *</label><input type="text" name="Name" id="hw_name" class="form-control" required /></div>
                <div class="col-6"><label class="form-label small">Highway ID *</label><input type="text" name="HighwayId" id="hw_hid" class="form-control font-monospace" required /></div>
                <div class="col-6"><label class="form-label small">State / Region</label><input type="text" name="State" id="hw_state" class="form-control" /></div>
                <div class="col-12"><label class="form-label small">Description</label><input type="text" name="Description" id="hw_desc" class="form-control" /></div>
                <div class="col-12">
                    <div class="form-check">
                        <input type="checkbox" name="IsActive" id="hw_active" class="form-check-input" value="true" checked />
                        <label class="form-check-label small" for="hw_active">Active</label>
                    </div>
                </div>
            </div>
        </form>
      </div>
      <div class="modal-footer border-top border-secondary">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" onclick="document.getElementById('hwForm').submit()">Save</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
function openNew() {
    document.getElementById('hwModalTitle').textContent = 'Add Highway';
    document.getElementById('hwForm').action = '/Settings/Create';
    document.getElementById('hw_id').value = 0;
    ['hw_name','hw_hid','hw_state','hw_desc'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('hw_active').checked = true;
}
function openEdit(id,name,hid,state,desc,active) {
    document.getElementById('hwModalTitle').textContent = 'Edit Highway';
    document.getElementById('hwForm').action = '/Settings/Edit';
    document.getElementById('hw_id').value = id;
    document.getElementById('hw_name').value = name;
    document.getElementById('hw_hid').value = hid;
    document.getElementById('hw_state').value = state;
    document.getElementById('hw_desc').value = desc;
    document.getElementById('hw_active').checked = (active === 'true' || active === true);
}
function toggleTomKey() {
    var i = document.getElementById('tomtomKey');
    var ic = document.getElementById('tomkeyIcon');
    if (i.type==='password'){i.type='text';ic.className='bi bi-eye-slash';}
    else{i.type='password';ic.className='bi bi-eye';}
}
</script>
}
