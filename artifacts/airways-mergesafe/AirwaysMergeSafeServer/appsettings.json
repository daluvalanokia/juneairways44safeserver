{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=mergesafe.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },

  // D7 FIX: Set to your actual domain(s) in production.
  // e.g. "AllowedHosts": "mergesafe.yourdomain.com;api.yourdomain.com"
  // Wildcard "*" left here for local dev only — override in appsettings.Production.json
  "AllowedHosts": "*",

  "TomTomApiKey": "",

  // DeviceApiKey — used by device ingest API (POST /api/events/ingest).
  // Set via environment variable DEVICE_API_KEY in production (do not commit a real key here).
  "DeviceApiKey": "",

  // E5 / D6: HeartbeatMonitor — tune timeouts to match your device heartbeat cadence
  "HeartbeatMonitor": {
    "SensorTimeoutMinutes":  5,
    "ServerTimeoutMinutes": 10,
    "PollIntervalMinutes":   2
  },

  // E6: Serilog — SEQ_URL env var enables optional Seq sink (e.g. http://seq:5341)
  // File logs written to /logs/mss-YYYYMMDD.log with 7-day rolling retention.
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
